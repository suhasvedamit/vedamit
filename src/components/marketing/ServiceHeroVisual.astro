<style>
  .service-hero-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .service-visual-svg {
    width: 100%;
    max-width: 20rem;
    height: auto;
    animation: service-visual-float 5.5s ease-in-out infinite;
  }

  @keyframes service-visual-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .service-visual-svg {
      animation: none;
    }
  }

  :global(.dark) .service-v-stroke {
    fill: color-mix(in oklch, var(--primary) 35%, transparent);
    stroke: color-mix(in oklch, var(--primary) 55%, transparent);
    stroke-width: 1.5;
  }

  .service-v-stroke {
    fill: color-mix(in oklch, var(--primary) 25%, transparent);
    stroke: color-mix(in oklch, var(--primary) 45%, transparent);
    stroke-width: 1.5;
  }

  .service-v-fill {
    fill: color-mix(in oklch, var(--primary) 85%, transparent);
  }

  .service-v-fill-soft {
    fill: color-mix(in oklch, var(--primary) 22%, transparent);
  }

  .service-v-rect {
    stroke: currentColor;
    stroke-width: 1.75;
    fill: color-mix(in oklch, var(--primary) 8%, transparent);
  }

  .service-v-rect-strong {
    stroke: currentColor;
    stroke-width: 2;
    fill: color-mix(in oklch, var(--primary) 14%, transparent);
  }

  .service-v-screen {
    stroke: color-mix(in oklch, currentColor 40%, transparent);
    stroke-width: 1.25;
    fill: color-mix(in oklch, var(--primary) 6%, transparent);
  }

  .service-v-line {
    stroke: currentColor;
    stroke-width: 1.75;
    stroke-linecap: round;
    stroke-opacity: 0.55;
    stroke-dasharray: 80;
    stroke-dashoffset: 80;
    animation: service-line-draw 2.2s ease forwards 0.15s;
  }

  .service-v-line-dashed {
    stroke-dasharray: 8 10;
    stroke-dashoffset: 0;
    animation: service-dash-shift 14s linear infinite;
    stroke-opacity: 0.4;
  }

  .service-v-arrow {
    stroke-dasharray: 40;
    stroke-dashoffset: 40;
    animation: service-line-draw 1.4s ease forwards 0.4s;
  }

  .service-v-spark {
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-opacity: 0.75;
    stroke-dasharray: 48;
    stroke-dashoffset: 48;
    animation: service-line-draw 1.6s ease forwards 0.5s;
  }

  .service-v-line-thin {
    stroke: currentColor;
    stroke-width: 1.25;
    stroke-opacity: 0.35;
    stroke-linecap: round;
  }

  @keyframes service-line-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes service-dash-shift {
    to {
      stroke-dashoffset: -180;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .service-v-line,
    .service-v-arrow,
    .service-v-spark {
      stroke-dashoffset: 0;
      animation: none;
    }
    .service-v-line-dashed {
      animation: none;
    }
    .service-webdev-cta {
      animation: none;
    }
    .service-webdev-metric-bar {
      animation: none;
      transform: none;
      opacity: 0.85;
    }
    .service-webdev-shine-sweep,
    .service-webdev-hero-panel,
    .service-webdev-card-float,
    .service-webdev-badge-pulse {
      animation: none !important;
    }
    .service-webdev-card-float {
      transform: none;
    }
    .service-webdev-hero-panel {
      opacity: 1;
    }
  }

  .service-visual-svg--webdev {
    max-width: 22rem;
  }

  .service-webdev-dot--r {
    fill: oklch(0.62 0.22 25 / 0.75);
  }

  .service-webdev-dot--y {
    fill: oklch(0.86 0.16 92 / 0.85);
  }

  .service-webdev-dot--g {
    fill: oklch(0.68 0.18 155 / 0.8);
  }

  .service-webdev-url-bar {
    fill: color-mix(in oklch, var(--primary) 12%, transparent);
    stroke: currentColor;
    stroke-width: 1;
    stroke-opacity: 0.2;
  }

  .service-webdev-hero-line {
    fill: color-mix(in oklch, white 55%, var(--primary) 45%);
    opacity: 0.85;
  }

  :global(.dark) .service-webdev-hero-line {
    fill: color-mix(in oklch, var(--foreground) 25%, var(--primary) 75%);
    opacity: 0.5;
  }

  .service-webdev-hero-line-muted {
    fill: color-mix(in oklch, var(--primary) 18%, transparent);
  }

  .service-webdev-cta {
    fill: color-mix(in oklch, var(--primary) 78%, white);
    stroke: currentColor;
    stroke-width: 1.25;
    stroke-opacity: 0.35;
    animation: service-webdev-cta-glow 2.4s ease-in-out infinite;
  }

  :global(.dark) .service-webdev-cta {
    fill: color-mix(in oklch, var(--primary) 55%, transparent);
  }

  @keyframes service-webdev-cta-glow {
    0%,
    100% {
      filter: drop-shadow(0 0 0 transparent);
      opacity: 1;
    }
    50% {
      filter: drop-shadow(0 0 10px color-mix(in oklch, var(--primary) 45%, transparent));
