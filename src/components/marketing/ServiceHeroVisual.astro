 ---
/**
 * Abstract SVG hero art per service — uses currentColor (inherit text-primary on wrapper).
 */
interface Props {
  slug: string;
  class?: string;
}

const { slug, class: className = "" } = Astro.props;

const visualId: Record<string, number> = {
  "ai-machine-learning": 0,
  "ai-automation": 1,
  "agentic-ai": 2,
  "ai-integration": 3,
  "ai-as-a-product": 4,
  "customized-ai-solutions": 5,
  "data-intelligence": 6,
  "full-stack-development": 7,
  "mobile-development": 8,
  "cloud-solutions": 9,
  cybersecurity: 10,
  "website-development": 11,
};

const id = visualId[slug] ?? 0;
