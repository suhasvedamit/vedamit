---
/**
 * Home hero (static). Replaces the previous React + Framer Motion island so the
 * homepage does not ship React, framer-motion, or lucide-react to the browser.
 */
type Props = {
  primaryCtaHref: string;
};

const { primaryCtaHref } = Astro.props;
---

<section
  class="home-hero-root relative flex min-h-[calc(100dvh-var(--site-header-height))] flex-col overflow-hidden border-b border-border/40"
>
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div
      class="absolute inset-0 bg-[linear-gradient(165deg,oklch(0.43_0.11_195/0.07)_0%,transparent_45%),linear-gradient(to_bottom,var(--background),var(--background))]"
      aria-hidden="true"
    >
    </div>
    <div
      class="home-hero-grid-bg absolute inset-0 opacity-[0.35] dark:opacity-[0.2]"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute left-1/2 top-0 h-[min(38rem,90vw)] w-[min(52rem,95vw)] -translate-x-1/2 rounded-full bg-primary/[0.12] blur-[80px] dark:bg-primary/[0.18]"
      aria-hidden="true"
    >
    </div>
  </div>

  <div
    class="mx-auto flex min-h-0 w-full max-w-7xl flex-1 flex-col justify-center px-4 py-10 sm:px-6 sm:py-12 lg:px-8 lg:py-14"
  >
    <div
      class="grid items-stretch gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:gap-14"
    >
      <div
        class="home-hero-stagger flex min-w-0 flex-col justify-center text-center lg:text-left"
      >
        <div
          class="home-hero-fade inline-flex w-fit max-w-full items-center gap-2 self-center rounded-full border border-primary/25 bg-primary/[0.07] px-3.5 py-1.5 text-xs font-medium tracking-wide text-primary shadow-sm backdrop-blur-sm lg:self-start"
        >
          <svg
            class="size-3.5 shrink-0"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"
            ></path>
            <path d="M20 2v4"></path>
            <path d="M22 4h-4"></path>
            <circle cx="4" cy="20" r="2"></circle>
          </svg>
          AI, automation & full‑stack — built to ship
        </div>

        <h1
          class="home-hero-fade font-heading mt-7 max-w-3xl text-left text-4xl font-semibold tracking-tight sm:text-5xl lg:text-6xl lg:leading-[1.06]"
        >
          Empowering businesses with{" "}
          <span
            class="bg-gradient-to-r from-primary to-[oklch(0.5_0.14_210)] bg-clip-text text-transparent dark:from-primary dark:to-[oklch(0.78_0.12_195)]"
          >
            cutting-edge AI and IT
          </span>{" "}
          solutions.
        </h1>

        <p
          class="home-hero-fade mt-4 max-w-2xl text-pretty text-left text-base leading-relaxed text-muted-foreground sm:text-lg"
        >
          Vedamit Solutions partners with teams to design and build AI products,
          resilient systems, and interfaces people trust — with clarity on
          scope, milestones, and measurable impact.
        </p>

        <div
          class="home-hero-fade mt-7 flex flex-col items-stretch gap-3 sm:flex-row sm:items-center sm:gap-4"
        >
          <a
            href={primaryCtaHref}
            class="inline-flex h-11 items-center justify-center gap-2 rounded-full bg-primary px-7 text-sm font-medium text-primary-foreground shadow-lg shadow-primary/25 transition-all hover:bg-primary/92 hover:shadow-xl hover:shadow-primary/30 active:scale-[0.98]"
          >
            Get in touch{" "}
            <svg
              class="size-4 shrink-0"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <div
        class="home-hero-fade-right relative mt-8 flex flex-col justify-center lg:mt-0"
      >
        <div
          class="pointer-events-none absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-primary/12 via-transparent to-indigo-500/10 blur-2xl dark:from-primary/18"
        >
        </div>
        <div class="relative grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
          <div
            class="rounded-2xl border border-border/60 bg-card/90 p-5 shadow-lg shadow-foreground/[0.04] backdrop-blur-md sm:col-span-2 lg:col-span-1"
          >
            <div class="flex items-start gap-3">
              <span
                class="grid size-10 shrink-0 place-items-center rounded-xl bg-primary/12 text-primary"
              >
                <svg
                  class="size-5"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M12 20v2"></path>
                  <path d="M12 2v2"></path>
                  <path d="M17 20v2"></path>
                  <path d="M17 2v2"></path>
                  <path d="M2 12h2"></path>
                  <path d="M2 17h2"></path>
                  <path d="M2 7h2"></path>
                  <path d="M20 12h2"></path>
                  <path d="M20 17h2"></path>
                  <path d="M20 7h2"></path>
                  <path d="M7 20v2"></path>
                  <path d="M7 2v2"></path>
                  <rect x="4" y="4" width="16" height="16" rx="2"></rect>
                  <rect x="8" y="8" width="8" height="8" rx="1"></rect>
                </svg>
              </span>
              <div class="min-w-0">
                <div class="text-sm font-semibold tracking-tight">
                  AI products that ship
                </div>
                <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                  From idea to production: LLM apps, RAG systems, and AI
                  copilots built around real business use‑cases.
                </p>
              </div>
            </div>
          </div>
          <div
            class="rounded-2xl border border-border/60 bg-card/90 p-5 shadow-md backdrop-blur-md"
          >
            <div
              class="flex items-center gap-2 text-sm font-semibold tracking-tight"
            >
              <span
                class="grid size-10 shrink-0 place-items-center rounded-xl bg-primary/12 text-primary"
              >
                <svg
                  class="size-4 text-primary"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path
                    d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83z"
                  ></path>
                  <path
                    d="M2 12a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 12"
                  ></path>
                  <path
                    d="M2 17a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 17"
                  ></path>
                </svg>
              </span>
              Automation & AI agents
            </div>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
              Workflow automation and agentic systems that take over repetitive
              work, connect your tools, and keep humans in control.
            </p>
          </div>
          <div
            class="rounded-2xl border border-border/60 bg-card/90 p-5 shadow-md backdrop-blur-md"
          >
            <div
              class="flex items-center gap-2 text-sm font-semibold tracking-tight"
            >
              <span
                class="grid size-10 shrink-0 place-items-center rounded-xl bg-primary/12 text-primary"
              >
                <svg
                  class="size-4 text-primary"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M11 13a3 3 0 1 1 2.83-4H14a2 2 0 0 1 0 4z"></path>
                  <path d="M12 17v4"></path>
                  <path d="M8 21h8"></path>
                  <rect x="2" y="3" width="20" height="14" rx="2"></rect>
                </svg>
              </span>
              Full‑stack engineering
            </div>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
              Modern web, mobile, and cloud infrastructure so your AI
              initiatives run on reliable, scalable products users love.
            </p>
          </div>
          <div
            class="rounded-2xl border border-border/60 bg-card/90 p-5 shadow-md backdrop-blur-md"
          >
            <div
              class="flex items-center gap-2 text-sm font-semibold tracking-tight"
            >
              <span
                class="grid size-10 shrink-0 place-items-center rounded-xl bg-primary/12 text-primary"
              >
                <svg
                  class="size-4 text-primary"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path
                    d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"
                  ></path>
                  <path d="M20 2v4"></path>
                  <path d="M22 4h-4"></path>
                  <circle cx="4" cy="20" r="2"></circle>
                </svg>
              </span>
              Strategy & discovery
            </div>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
              Roadmapping, architecture decisions, and quick experiments to
              validate what to build before you invest in full delivery.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .home-hero-grid-bg {
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: linear-gradient(
      to bottom,
      black 0%,
      black 50%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      black 0%,
      black 50%,
      transparent 100%
    );
  }

  @keyframes home-hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .home-hero-fade {
    opacity: 0;
    animation: home-hero-fade-up 0.55s ease forwards;
  }

  .home-hero-stagger .home-hero-fade:nth-child(1) {
    animation-delay: 0s;
  }
  .home-hero-stagger .home-hero-fade:nth-child(2) {
    animation-delay: 0.09s;
  }
  .home-hero-stagger .home-hero-fade:nth-child(3) {
    animation-delay: 0.18s;
  }
  .home-hero-stagger .home-hero-fade:nth-child(4) {
    animation-delay: 0.27s;
  }

  .home-hero-fade-right {
    opacity: 0;
    animation: home-hero-fade-up 0.6s ease 0.15s forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .home-hero-fade,
    .home-hero-fade-right {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
