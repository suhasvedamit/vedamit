---
import { sitePath } from "../../lib/site";

type Props = {
  href: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md";
  class?: string;
  ariaCurrent?: "page";
  target?: string;
  rel?: string;
};

const {
  href,
  variant = "primary",
  size = "md",
  class: className,
  ariaCurrent,
  target,
  rel,
} = Astro.props;

const resolvedHref =
  href.startsWith("/") && !href.startsWith("//") ? sitePath(href) : href;

const base =
  "inline-flex items-center justify-center rounded-xl font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background disabled:pointer-events-none disabled:opacity-50";

const sizes: Record<NonNullable<Props["size"]>, string> = {
  sm: "h-9 px-4 text-sm",
  md: "h-11 px-5 text-sm",
};

const variants: Record<NonNullable<Props["variant"]>, string> = {
  primary:
    "bg-[linear-gradient(135deg,rgb(var(--brand-glow-1)/0.95),rgb(var(--brand-glow-2)/0.95))] text-primary-foreground shadow-sm hover:opacity-95",
  secondary:
    "border border-border bg-background/70 text-foreground shadow-sm backdrop-blur hover:bg-accent/70",
  ghost: "text-foreground/90 hover:bg-accent/70 hover:text-foreground",
};
---

<a
  href={resolvedHref}
  target={target}
  rel={rel}
  class:list={[base, sizes[size], variants[variant], className]}
  aria-current={ariaCurrent}
>
  <slot />
</a>
