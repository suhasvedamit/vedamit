---
import Container from "./Container.astro";
import LinkButton from "./LinkButton.astro";
---

<section class="relative overflow-hidden border-t border-border/60">
  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-br from-primary/[0.09] via-secondary/40 to-indigo-500/[0.06] dark:from-primary/[0.12] dark:via-secondary/20"
    aria-hidden="true"
  >
  </div>
  <Container wide class="relative py-16 sm:py-20">
    <div
      class="rounded-[1.75rem] border border-border/60 bg-card/80 p-8 shadow-xl shadow-foreground/[0.04] backdrop-blur-sm sm:p-10 lg:p-12"
    >
      <div class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
        <div>
          <p
            class="text-xs font-semibold uppercase tracking-[0.14em] text-primary"
          >
            Next step
          </p>
          <h2
            class="font-heading mt-3 text-balance text-2xl font-semibold tracking-tight sm:text-3xl lg:text-[2.125rem]"
          >
            Ready to move from idea to shipped software?
          </h2>
          <p class="mt-4 max-w-xl text-sm leading-relaxed text-muted-foreground sm:text-base">
            Share what you’re building. We’ll respond with a practical plan,
            rough timeline, and how we’d collaborate — no fluff.
          </p>
        </div>
        <div
          class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:justify-end lg:flex-col xl:flex-row xl:justify-end"
        >
          <LinkButton href="/contact" variant="primary" class="w-full sm:w-auto"
            >Get started</LinkButton
          >
          <LinkButton
            href="/services"
            variant="secondary"
            class="w-full sm:w-auto">Browse services</LinkButton
          >
        </div>
      </div>
    </div>
  </Container>
</section>
