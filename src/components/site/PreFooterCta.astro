---
import Container from "./Container.astro";
import LinkButton from "./LinkButton.astro";
---

<section class="border-t border-border/60 bg-secondary/30 py-14 sm:py-16">
  <Container>
    <div class="grid gap-8 lg:grid-cols-3 lg:items-center">
      <div class="lg:col-span-2">
        <h2
          class="text-balance text-2xl font-semibold tracking-tight sm:text-3xl"
        >
          Ready to Transform Your Business?
        </h2>
        <p class="mt-3 text-sm text-muted-foreground sm:text-base">
          Tell us what you’re building. We’ll reply with a clear plan, timeline,
          and next steps.
        </p>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row lg:justify-end">
        <LinkButton href="/contact" variant="primary" class="w-full sm:w-auto"
          >Get started</LinkButton
        >
        <LinkButton
          href="/services"
          variant="secondary"
          class="w-full sm:w-auto">View services</LinkButton
        >
      </div>
    </div>
  </Container>
</section>
