---
import Layout from "../layouts/Layout.astro";
import Container from "../components/site/Container.astro";
import PageHero from "../components/site/PageHero.astro";

const values = [
  {
    title: "Excellence",
    body: "We strive for excellence in everything we do, delivering the highest quality solutions and services to our clients.",
  },
  {
    title: "Innovation",
    body: "We continuously push the boundaries of what's possible, embracing new technologies and approaches to solve complex challenges.",
  },
  {
    title: "Trust",
    body: "We build and maintain trust through transparency, reliability, and consistent delivery of exceptional results.",
  },
  {
    title: "Client Success",
    body: "We are committed to our clients' success, working as true partners to achieve their business objectives.",
  },
] as const;
---

<Layout
  title="About Us — Vedamit Solutions"
  description="We are a team of AI and technology experts dedicated to transforming businesses through innovative solutions."
  canonicalPath="/about"
>
  <section class="py-10 sm:py-13 lg:py-15">
    <Container wide>
      <PageHero
        badge="About"
        title="About Us"
        description="We are a team of AI and technology experts dedicated to transforming businesses through innovative solutions."
      />

      <div class="mx-auto mt-14 max-w-3xl space-y-14">
        <div>
          <h2 class="font-heading text-xl font-semibold tracking-tight sm:text-2xl">
            Our Mission
          </h2>
          <p class="mt-4 text-base leading-relaxed text-muted-foreground">
            To empower businesses with cutting-edge AI solutions that drive
            innovation, efficiency, and growth. We are committed to delivering
            transformative technology that helps our clients stay ahead in the
            digital age.
          </p>
        </div>

        <div>
          <h2 class="font-heading text-xl font-semibold tracking-tight sm:text-2xl">
            Our Vision
          </h2>
          <p class="mt-4 text-base leading-relaxed text-muted-foreground">
            To be the leading force in AI-driven business transformation,
            recognized globally for our innovative solutions and commitment to
            client success. We envision a future where AI technology makes
            businesses more efficient, intelligent, and sustainable.
          </p>
        </div>

        <div>
          <h2 class="font-heading text-xl font-semibold tracking-tight sm:text-2xl">
            Our Core Values
          </h2>
          <p class="mt-3 text-base text-muted-foreground">
            The principles that guide our work and relationships
          </p>
          <div class="mt-10 grid gap-5 sm:grid-cols-2">
            {
              values.map((v) => (
                <article class="rounded-2xl border border-border/60 bg-card p-7 shadow-sm transition hover:border-primary/20">
                  <h3 class="text-base font-semibold tracking-tight">
                    {v.title}
                  </h3>
                  <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                    {v.body}
                  </p>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </Container>
  </section>
</Layout>
