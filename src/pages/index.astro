---
import Layout from "../layouts/Layout.astro";
import Container from "../components/site/Container.astro";
import LinkButton from "../components/site/LinkButton.astro";
import { services } from "../data/services";
import { whyChooseUs, stats, trustedBy } from "../data/home-marketing";
import { HeroMotion } from "../components/marketing/HeroMotion";
---

<Layout
  title="Vedamit Solutions — Premium AI & Software Development"
  description="Premium, modern, trustworthy AI, automation, and full‑stack development services."
  canonicalPath="/"
>
  <HeroMotion
    primaryCtaHref="/contact"
    secondaryCtaHref="/services"
    client:load
  />

  <section class="py-14 sm:py-16">
    <Container>
      <div class="flex items-end justify-between gap-6">
        <div class="max-w-2xl">
          <h2
            class="text-balance text-2xl font-semibold tracking-tight sm:text-3xl"
          >
            Services designed for outcomes
          </h2>
          <p class="mt-3 text-sm text-muted-foreground sm:text-base">
            From strategy to production, we build dependable systems with
            excellent UX, clear metrics, and fast iteration.
          </p>
        </div>
        <div class="hidden sm:block">
          <LinkButton href="/services" variant="secondary"
            >Explore all services</LinkButton
          >
        </div>
      </div>

      <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {
          services.slice(0, 3).map((svc) => (
            <a
              href="/services"
              class="group rounded-2xl border border-border/60 bg-card p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-border hover:shadow-md"
            >
              <div class="text-base font-semibold tracking-tight">
                {svc.title}
              </div>
              <p class="mt-2 text-sm text-muted-foreground">
                {svc.description}
              </p>
              <div class="mt-4 text-sm font-medium text-foreground/90 group-hover:text-foreground">
                Learn more →
              </div>
            </a>
          ))
        }
      </div>

      <div class="mt-8 sm:hidden">
        <LinkButton href="/services" variant="secondary" class="w-full"
          >Explore all services</LinkButton
        >
      </div>
    </Container>
  </section>

  <section class="border-t border-border/60 py-14 sm:py-16">
    <Container>
      <div class="max-w-2xl">
        <h2
          class="text-balance text-2xl font-semibold tracking-tight sm:text-3xl"
        >
          {whyChooseUs.title}
        </h2>
        <p class="mt-3 text-sm text-muted-foreground sm:text-base">
          {whyChooseUs.subtitle}
        </p>
      </div>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          whyChooseUs.items.map((item) => (
            <div class="rounded-2xl border border-border/60 bg-card p-5 shadow-sm">
              <h3 class="text-base font-semibold tracking-tight">
                {item.title}
              </h3>
              <p class="mt-2 text-sm text-muted-foreground">
                {item.description}
              </p>
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <section class="border-t border-border/60 bg-secondary/30 py-14 sm:py-16">
    <Container>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          stats.map((stat) => (
            <div class="flex flex-col items-center justify-center rounded-2xl border border-border/60 bg-card px-4 py-8 text-center shadow-sm">
              <div class="text-3xl font-semibold tracking-tight sm:text-4xl">
                {stat.value}
              </div>
              <div class="mt-2 text-sm font-medium text-muted-foreground">
                {stat.label}
              </div>
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <section class="border-t border-border/60 py-14 sm:py-16">
    <Container>
      <div class="max-w-2xl">
        <h2
          class="text-balance text-2xl font-semibold tracking-tight sm:text-3xl"
        >
          {trustedBy.title}
        </h2>
        <p class="mt-3 text-sm text-muted-foreground sm:text-base">
          {trustedBy.subtitle}
        </p>
      </div>
      <div
        class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5"
      >
        {
          trustedBy.partners.map((p) => (
            <div class="group flex min-h-[7.5rem] items-center justify-center rounded-2xl border border-border/60 bg-card p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-border hover:shadow-md">
              <img
                src={p.logoSrc}
                alt={`${p.name} logo`}
                class="h-12 w-auto max-h-14 max-w-[9rem] object-contain grayscale opacity-55 transition group-hover:grayscale-0 group-hover:opacity-100 sm:h-14 sm:max-h-16"
                loading="lazy"
                decoding="async"
              />
            </div>
          ))
        }
      </div>
    </Container>
  </section>
</Layout>
