---
import Layout from "../layouts/Layout.astro";
import Container from "../components/site/Container.astro";
import LinkButton from "../components/site/LinkButton.astro";
import { services } from "../data/services";
import { whyChooseUs, stats, trustedBy } from "../data/home-marketing";
import { HeroMotion } from "../components/marketing/HeroMotion";
import { sitePath } from "../lib/site";
---

<Layout
  title="Vedamit Solutions"
  description="AI, automation, and full‑stack development services."
  canonicalPath="/"
>
  <HeroMotion
    primaryCtaHref={sitePath("/contact")}
    secondaryCtaHref={sitePath("/services")}
    client:load
  />

  <section class="py-16 sm:py-20">
    <Container wide>
      <div
        class="flex flex-col justify-between gap-8 sm:flex-row sm:items-end"
      >
        <div class="max-w-2xl">
          <p
            class="text-xs font-semibold uppercase tracking-[0.14em] text-primary"
          >
            What we do
          </p>
          <h2
            class="font-heading mt-3 text-balance text-2xl font-semibold tracking-tight sm:text-3xl lg:text-4xl"
          >
            Services designed for outcomes
          </h2>
          <p class="mt-4 text-base leading-relaxed text-muted-foreground">
            From discovery to production, we build dependable systems with
            excellent UX, observable behavior, and room to iterate.
          </p>
        </div>
        <div class="hidden shrink-0 sm:block">
          <LinkButton href="/services" variant="secondary"
            >Explore all services</LinkButton
          >
        </div>
      </div>

      <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3 lg:gap-6">
        {
          services.slice(0, 3).map((svc, i) => (
            <a
              href={sitePath("/services")}
              class="group relative overflow-hidden rounded-2xl border border-border/60 bg-card p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/25 hover:shadow-xl hover:shadow-primary/5"
            >
              <span
                class="absolute right-4 top-4 font-heading text-4xl font-bold tabular-nums text-primary/[0.12] transition-colors group-hover:text-primary/20"
                aria-hidden="true"
              >
                {String(i + 1).padStart(2, "0")}
              </span>
              <div class="relative">
                <h3 class="text-lg font-semibold tracking-tight">{svc.title}</h3>
                <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                  {svc.description}
                </p>
                <div class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-primary transition group-hover:gap-2">
                  Learn more
                  <span aria-hidden="true">→</span>
                </div>
              </div>
            </a>
          ))
        }
      </div>

      <div class="mt-10 sm:hidden">
        <LinkButton href="/services" variant="secondary" class="w-full"
          >Explore all services</LinkButton
        >
      </div>
    </Container>
  </section>

  <section class="border-t border-border/50 bg-muted/30 py-16 sm:py-20">
    <Container wide>
      <div class="max-w-2xl">
        <p
          class="text-xs font-semibold uppercase tracking-[0.14em] text-primary"
        >
          Why Vedamit
        </p>
        <h2
          class="font-heading mt-3 text-balance text-2xl font-semibold tracking-tight sm:text-3xl lg:text-4xl"
        >
          {whyChooseUs.title}
        </h2>
        <p class="mt-4 text-base leading-relaxed text-muted-foreground">
          {whyChooseUs.subtitle}
        </p>
      </div>
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4 lg:gap-6">
        {
          whyChooseUs.items.map((item) => (
            <div class="rounded-2xl border border-border/50 bg-card p-6 shadow-sm transition hover:border-primary/20">
              <div
                class="h-1 w-10 rounded-full bg-gradient-to-r from-primary to-primary/50"
                aria-hidden="true"
              >
              </div>
              <h3 class="mt-4 text-base font-semibold tracking-tight">
                {item.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                {item.description}
              </p>
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <section class="border-t border-border/50 py-14 sm:py-20">
    <Container wide>
      <div class="grid gap-4 grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 lg:gap-6">
        {
          stats.map((stat) => (
            <div class="relative overflow-hidden rounded-2xl border border-border/60 bg-gradient-to-br from-card to-muted/40 px-4 py-7 text-center shadow-sm">
              <div class="font-heading text-2xl font-semibold tabular-nums tracking-tight text-foreground sm:text-3xl lg:text-4xl">
                {stat.value}
              </div>
              <div class="mt-1.5 text-xs sm:text-sm font-medium text-muted-foreground">
                {stat.label}
              </div>
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <section class="border-t border-border/50 bg-muted/25 py-16 sm:py-20">
    <Container wide>
      <div class="max-w-2xl">
        <p
          class="text-xs font-semibold uppercase tracking-[0.14em] text-primary"
        >
          Partners
        </p>
        <h2
          class="font-heading mt-3 text-balance text-2xl font-semibold tracking-tight sm:text-3xl lg:text-4xl"
        >
          {trustedBy.title}
        </h2>
        <p class="mt-4 text-base leading-relaxed text-muted-foreground">
          {trustedBy.subtitle}
        </p>
      </div>
      <div class="mt-12 -mx-4 overflow-hidden">
        <div class="partners-marquee px-4">
          <div class="partners-marquee-track">
            {
              [...trustedBy.partners, ...trustedBy.partners].map((p) => (
                <div class="group flex min-h-[7.5rem] w-56 flex-shrink-0 items-center justify-center rounded-2xl border border-border/60 bg-card p-6 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/25 hover:shadow-md">
                  <img
                    src={sitePath(p.logoSrc)}
                    alt={`${p.name} logo`}
                    class="h-12 w-auto max-h-14 max-w-[9rem] object-contain opacity-50 grayscale transition duration-300 group-hover:opacity-100 group-hover:grayscale-0 sm:h-14 sm:max-h-16"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </Container>
  </section>

<style is:global>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  .partners-marquee {
    position: relative;
    overflow: hidden;
  }

  .partners-marquee-track {
    display: inline-flex;
    gap: 1rem;
    animation: partners-scroll 30s linear infinite;
  }

  .partners-marquee:hover .partners-marquee-track {
    animation-play-state: paused;
  }

  @keyframes partners-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
</Layout>
