---
import "../styles/global.css";
import { ViewTransitions } from "astro:transitions";
import Header from "../components/site/Header.astro";
import Footer from "../components/site/Footer.astro";
import PreFooterCta from "../components/site/PreFooterCta.astro";

type Props = {
  title: string;
  description?: string;
  canonicalPath?: string;
  /** Absolute path for Open Graph / Twitter image (default: /og-default.png). */
  imagePath?: string;
  /** When false, hides the “Ready to Transform Your Business?” strip above the footer (e.g. contact page). */
  preFooterCta?: boolean;
  /** When true, main height follows content only (e.g. 404) so the footer stays easier to see. */
  compactMain?: boolean;
};

const {
  title,
  description,
  canonicalPath,
  imagePath = "/og-default.png",
  preFooterCta = true,
  compactMain = false,
} = Astro.props;

const siteOrigin = Astro.site ?? new URL("https://vedamit.com");

function normalizeCanonicalPath(p: string): string {
  if (!p || p === "/") return "/";
  return p.replace(/\/+$/, "");
}

const canonicalUrl = canonicalPath
  ? new URL(normalizeCanonicalPath(canonicalPath), siteOrigin).toString()
  : undefined;

const ogImageUrl = new URL(imagePath.replace(/^\//, ""), siteOrigin).toString();
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    {canonicalUrl ? <link rel="canonical" href={canonicalUrl} /> : null}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Vedamit Solutions" />
    <meta property="og:title" content={title} />
    {
      description ? (
        <meta property="og:description" content={description} />
      ) : null
    }
    {canonicalUrl ? <meta property="og:url" content={canonicalUrl} /> : null}
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {
      description ? (
        <meta name="twitter:description" content={description} />
      ) : null
    }
    <meta name="twitter:image" content={ogImageUrl} />
    <ViewTransitions />
  </head>
  <body class="min-h-dvh bg-background text-foreground antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 rounded-md bg-background px-4 py-2 text-sm font-medium shadow"
    >
      Skip to content
    </a>
    <Header />
    <main id="main" class:list={[!compactMain && "min-h-[60dvh]"]}>
      <slot />
    </main>
    {preFooterCta ? <PreFooterCta /> : null}
    <Footer />
  </body>
</html>
