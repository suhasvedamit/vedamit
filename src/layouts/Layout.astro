---
import "../styles/global.css";
import { ViewTransitions } from "astro:transitions";
import Header from "../components/site/Header.astro";
import Footer from "../components/site/Footer.astro";
import PreFooterCta from "../components/site/PreFooterCta.astro";
import { sitePath } from "../lib/site";

type Props = {
  title: string;
  description?: string;
  canonicalPath?: string;
  /** Absolute path for Open Graph / Twitter image (default: /og-default.png). */
  imagePath?: string;
  /** When false, hides the “Ready to Transform Your Business?” strip above the footer (e.g. contact page). */
  preFooterCta?: boolean;
  /** When true, main height follows content only (e.g. 404) so the footer stays easier to see. */
  compactMain?: boolean;
};

const {
  title,
  description,
  canonicalPath,
  imagePath = "/og-default.png",
  preFooterCta = true,
  compactMain = false,
} = Astro.props;

const siteOrigin = Astro.site ?? new URL("https://vedamit.com");
const originHref = siteOrigin.href.replace(/\/+$/, "");

function normalizeCanonicalPath(p: string): string {
  if (!p || p === "/") return "/";
  return p.replace(/\/+$/, "");
}

/** Full pathname including `base` (e.g. /vedamit/about) for canonical and OG URLs. */
function absoluteSitePath(path: string): string {
  const baseSegment = import.meta.env.BASE_URL.replace(/^\/+|\/+$/g, "");
  const part = normalizeCanonicalPath(path);
  if (part === "/") return baseSegment ? `/${baseSegment}/` : "/";
  return baseSegment ? `/${baseSegment}${part}` : part;
}

const canonicalUrl = canonicalPath
  ? `${originHref}${absoluteSitePath(canonicalPath)}`
  : undefined;

const ogImageUrl = `${originHref}${absoluteSitePath(imagePath)}`;

const gaMeasurementId = "G-JMKW9PD7H5";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    {canonicalUrl ? <link rel="canonical" href={canonicalUrl} /> : null}
    <link rel="icon" type="image/svg+xml" href={sitePath("/favicon.svg")} />
    <link rel="icon" type="image/png" sizes="32x32" href={sitePath("/favicon.png")} />
    <link rel="icon" href={sitePath("/favicon.ico")} sizes="any" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Vedamit Solutions" />
    <meta property="og:title" content={title} />
    {
      description ? (
        <meta property="og:description" content={description} />
      ) : null
    }
    {canonicalUrl ? <meta property="og:url" content={canonicalUrl} /> : null}
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {
      description ? (
        <meta name="twitter:description" content={description} />
      ) : null
    }
    <meta name="twitter:image" content={ogImageUrl} />
    {
      import.meta.env.PROD ? (
        <>
          <script
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}
          />
          <script is:inline define:vars={{ gaMeasurementId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag("js", new Date());
            document.addEventListener("astro:page-load", () => {
              gtag("config", gaMeasurementId, {
                page_path:
                  window.location.pathname + window.location.search,
              });
            });
          </script>
        </>
      ) : null
    }
    <ViewTransitions />
  </head>
  <body
    class="min-h-dvh bg-background text-foreground selection:bg-primary/15 selection:text-foreground"
  >
    <div
      class="pointer-events-none fixed inset-0 -z-10 overflow-hidden"
      aria-hidden="true"
    >
      <div
        class="absolute -left-1/4 top-[-20%] h-[55%] w-[70%] rounded-full bg-primary/[0.055] blur-[100px]"
      >
      </div>
      <div
        class="absolute -right-1/5 top-[35%] h-[45%] w-[55%] rounded-full bg-indigo-500/[0.07] blur-[90px] dark:bg-indigo-400/[0.08]"
      >
      </div>
      <div
        class="absolute inset-0 bg-[linear-gradient(to_bottom,transparent_0%,var(--background)_55%,var(--background)_100%)]"
      >
      </div>
    </div>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 rounded-lg border border-border bg-card px-4 py-2 text-sm font-medium shadow-lg"
    >
      Skip to content
    </a>
    <Header />
    <main id="main" class:list={[!compactMain && "min-h-[60dvh]"]}>
      <slot />
    </main>
    {preFooterCta ? <PreFooterCta /> : null}
    <Footer />
  </body>
</html>
