{
  "name": "vedamit_website",
  "type": "module",
  "version": "0.0.1",
  "homepage": "https://vedamit.com/",
  "config": {
    "ghpages_site": "https://vedamit.com",
    "ghpages_base": "vedamit"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "verify": "npm run check && npm run lint && npm run build",
    "build:pages": "GITHUB_PAGES=true GHPAGES_NO_BASE=true astro build",
    "build:pages:subpath": "GITHUB_PAGES=true astro build",
    "deploy": "npm run build:pages && gh-pages -d dist -r https://github.com/suhasvedamit/vedamit.git --cname vedamit.com"
  },
  "dependencies": {
    "@astrojs/react": "^3.6.3",
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@fontsource-variable/comfortaa": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "astro": "^4.16.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/node": "^22.19.15",
    "gh-pages": "^6.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3"
  }
}
